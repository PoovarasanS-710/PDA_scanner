<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Top bar: title + scan count -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="@dimen/top_bar_height"
        android:orientation="horizontal"
        android:background="@color/colorPrimary"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textColor="@color/colorAccent"
            android:textStyle="bold"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/textScanCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_scan_count"
            android:textColor="@color/colorTextSecondary"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Scan list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerScans"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/buttonRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Empty state (visible when 0 scans) -->
    <TextView
        android:id="@+id/textEmpty"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Press SCAN to begin"
        android:textColor="@color/colorTextSecondary"
        android:textSize="16sp"
        android:gravity="center"
        android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/buttonRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom button row -->
    <LinearLayout
        android:id="@+id/buttonRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/button_row_padding"
        android:background="@color/colorPrimary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- SCAN button — takes twice the space -->
        <Button
            android:id="@+id/btnScan"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="2"
            android:layout_marginEnd="4dp"
            android:text="@string/btn_scan"
            android:textColor="@color/colorButtonText"
            android:textStyle="bold"
            android:textSize="@dimen/button_text_size"
            android:backgroundTint="@color/colorButtonScan" />

        <!-- EXPORT button -->
        <Button
            android:id="@+id/btnExport"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:text="@string/btn_export"
            android:textColor="@color/colorOnPrimary"
            android:textStyle="bold"
            android:textSize="12sp"
            android:backgroundTint="@color/colorButtonExport"
            android:enabled="false"
            android:alpha="0.4" />

        <!-- LOGOUT button -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="@string/btn_logout"
            android:textColor="@color/colorOnPrimary"
            android:textStyle="bold"
            android:textSize="12sp"
            android:backgroundTint="@color/colorButtonLogout" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
